# ============================================
# AutoResearch Agent - Environment Variables
# ============================================
#
# 1. Copy this file to .env (without .example)
# 2. Fill in your actual API keys
# 3. NEVER commit .env to GitHub!
# ============================================

# Google Gemini API Key (REQUIRED)
# Free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Tavily Search API Key (REQUIRED)
# Free at: https://app.tavily.com (1,000 searches/month)
TAVILY_API_KEY=your_tavily_api_key_here

# Chainlit auth secret (auto-generated, just leave default)
CHAINLIT_AUTH_SECRET=your_random_secret_here_change_in_production

# Model Configuration
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Agent Configuration
MAX_RESEARCH_ITERATIONS=5
MAX_SEARCH_RESULTS=10
MAX_CONTENT_LENGTH=5000

# Vector Database
CHROMA_DB_PATH=./chroma_db
COLLECTION_NAME=research_memory
